    "shell": {
      "enabled": true,
      "decodeJsonStdout": false,
      "program": "sh",
      "argsTemplate": ["-c", "printf '%s\\n' '{locator}'"],
      "workingDir": ".",
      "timeoutMs": 60000,
      "capture": {
        "stdout": true,
        "stderr": true,
        "maxBytes": 1048576
      },
      "strictTemplating": true,
      "killProcessGroup": true,
