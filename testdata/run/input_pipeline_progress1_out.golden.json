    "lua": {
      "filterInline": "return string.sub(locator, -3) == \".go\"\n  and string.sub(locator, -8) ~= \"_test.go\"",
      "mapInline": "return {\n  kind = \"go\",\n}",
      "postMapInline": "return {\n  meta = {\n    kind = mapped and mapped.kind,\n    shellLocator = shell and shell.stdout,\n  },\n}"
